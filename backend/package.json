{
  "name": "imaginexplainer-backend",
  "version": "1.0.0",
  "description": "Enterprise API & Worker for ImagineXplainer",
  "main": "src/api/index.ts",
  "scripts": {
    "preinstall": "npm audit --audit-level=high",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "build": "tsc",
    "start": "concurrently \"npm run start:api\" \"npm run start:worker\"",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "cloudconvert": "^3.0.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "duck-duck-scrape": "^2.2.7",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "node-edge-tts": "^1.2.10",
    "pg": "^8.11.5",
    "pptxgenjs": "^4.0.1",
    "rate-limit-redis": "^4.3.1",
    "stripe": "^21.0.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
