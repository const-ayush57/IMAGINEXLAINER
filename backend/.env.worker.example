# [Background Worker Environment Variables (.env.worker)]
# Rename to .env.worker when populated locally!

# -----------------
# INFRASTRUCTURE
# -----------------

# PostgreSQL Database URL
# Used to update Job Status (`processing`, `completed`, `failed`)
# Obtain this from Supabase or Neon.tech
DATABASE_URL=

# Redis / Upstash Connection String
# Used by BullMQ background polling daemon
# Obtain this from Upstash Free Tier
REDIS_URL=

# -----------------
# AI "BRAINS"
# -----------------

# Groq Inference API Key
# Obtain this completely free at https://console.groq.com/keys
GROQ_API_KEY=

# CloudConvert Engine
# Powers stealthy `.pptx` to `.mp4` transcoding natively tracking outputs securely.
CLOUDCONVERT_API_KEY=
