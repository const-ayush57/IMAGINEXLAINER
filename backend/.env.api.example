# [API Server Environment Variables (.env.api)]
# Rename to .env.api when populated locally!

# -----------------
# SYSTEM & SECURITY
# -----------------
API_PORT=3000

# JSON Web Token Secret
# Used to sign HTTP-only cookies securely. Generate a long, random string.
JWT_SECRET=your_super_secret_jwt_string

# -----------------
# INFRASTRUCTURE
# -----------------

# PostgreSQL Database URL
# Obtain this by creating a free database on Supabase or Neon.tech
# Format: postgresql://[user]:[password]@[host]:5432/[db]
DATABASE_URL=

# Redis / Upstash Connection String
# Obtain this from Upstash Free Tier console (Required for `express-rate-limit`)
# Format: redis://default:[password]@[endpoint]:[port]
REDIS_URL=

# -----------------
# MONETIZATION
# -----------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
